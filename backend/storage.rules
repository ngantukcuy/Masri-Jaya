rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Foto produk diunggah lewat modul Tambah Produk / Product Master.
    // Sama seperti Firestore rules: cukup butuh user yang sudah signed-in
    // (anonim otomatis dari frontend/src/lib/firebase.ts).
    match /product-images/{fileName} {
      allow read: if true; // gambar produk ditampilkan di halaman publik (Toko Digital, dsb)
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
