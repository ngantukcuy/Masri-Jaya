rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // All app data lives under the "tokku" collection, one document per
    // "table" (products, customers, salesInvoices, ...). See
    // frontend/src/lib/useFirestoreState.ts.
    //
    // NOTE: this app doesn't have real user authentication wired up yet
    // (LoginView.tsx checks a PIN client-side only), so these rules just
    // require *some* signed-in Firebase user -- good enough to keep the
    // database off the public internet during development, but NOT a
    // substitute for real auth + per-role rules before going to production.
    match /tokku/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
